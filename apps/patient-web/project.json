{
  "name": "patient-web",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/patient-web",
  "projectType": "application",
  "tags": [],
  "// targets": "to see all targets run: nx show project patient-web --web",
  "targets": {
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "next dev",
        "cwd": "apps/patient-web"
      }
    },
    "build": {
      "executor": "@nx/next:build",
      "options": {
        "outputPath": "dist/apps/patient-web"
      }
    }
  }
}