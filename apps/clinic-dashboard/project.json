{
  "name": "clinic-dashboard",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "app",
  "sourceRoot": "apps/clinic-dashboard/src",
  "tags": ["scope:shared"],
  "targets": {
    "build": {
      "executor": "@angular-devkit/build-angular:browser",
      "outputs": [
        "{options.outputPath}"
      ],
      "options": {
        "outputPath": "dist/apps/clinic-dashboard/browser",
        "index": "apps/clinic-dashboard/src/index.html",
        "main": "apps/clinic-dashboard/src/main.ts",
        "tsConfig": "apps/clinic-dashboard/tsconfig.app.json",
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/clinic-dashboard/public"
          }
        ],
        "styles": [
          "apps/clinic-dashboard/src/styles.scss"
        ]
      },
      "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "500kb",
              "maximumError": "1mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "4kb",
              "maximumError": "8kb"
            }
          ],
          "outputHashing": "all"
        },
        "development": {
          "buildOptimizer": false,
          "optimization": false,
          "vendorChunk": true,
          "extractLicenses": false,
          "sourceMap": true,
          "namedChunks": true
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "continuous": true,
      "executor": "@angular-devkit/build-angular:dev-server",
      "options": {
        "proxyConfig": "apps/clinic-dashboard/proxy.conf.json"
      },
      "configurations": {
        "production": {
          "buildTarget": "clinic-dashboard:build:production"
        },
        "development": {
          "buildTarget": "clinic-dashboard:build:development"
        }
      },
      "defaultConfiguration": "development"
    },
    "extract-i18n": {
      "executor": "@angular-devkit/build-angular:extract-i18n",
      "options": {
        "buildTarget": "clinic-dashboard:build"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "serve-static": {
      "continuous": true,
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "clinic-dashboard:build",
        "port": 4200,
        "spa": true
      }
    },
    "server": {
      "dependsOn": [
        "build"
      ],
      "executor": "@angular-devkit/build-angular:server",
      "options": {
        "outputPath": "dist/apps/clinic-dashboard/server",
        "main": "apps/clinic-dashboard/src/server.ts",
        "tsConfig": "apps/clinic-dashboard/tsconfig.server.json"
      },
      "configurations": {
        "production": {
          "outputHashing": "media"
        },
        "development": {
          "buildOptimizer": false,
          "optimization": false,
          "sourceMap": true,
          "extractLicenses": false,
          "vendorChunk": true
        }
      },
      "defaultConfiguration": "production"
    },
    "serve-ssr": {
      "continuous": true,
      "executor": "@angular-devkit/build-angular:ssr-dev-server",
      "configurations": {
        "development": {
          "browserTarget": "clinic-dashboard:build:development",
          "serverTarget": "clinic-dashboard:server:development"
        },
        "production": {
          "browserTarget": "clinic-dashboard:build:production",
          "serverTarget": "clinic-dashboard:server:production"
        }
      },
      "defaultConfiguration": "development"
    },
    "prerender": {
      "executor": "@angular-devkit/build-angular:prerender",
      "options": {
        "routes": [
          "/"
        ]
      },
      "configurations": {
        "development": {
          "browserTarget": "clinic-dashboard:build:development",
          "serverTarget": "clinic-dashboard:server:development"
        },
        "production": {
          "browserTarget": "clinic-dashboard:build:production",
          "serverTarget": "clinic-dashboard:server:production"
        }
      },
      "defaultConfiguration": "production"
    }
  }
}
